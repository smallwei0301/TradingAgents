# OpenClaw -> TradingAgents runtime configuration
# Copy selected values into your deployment secrets/env. Do not commit real keys.

# LLM provider selection
TRADINGAGENTS_LLM_PROVIDER=openai
TRADINGAGENTS_QUICK_MODEL=gpt-5.4-mini
TRADINGAGENTS_DEEP_MODEL=gpt-5.4
# TRADINGAGENTS_BACKEND_URL=

# Provider credentials. Set only what you use.
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=

# Optional market data provider key. Not required for default yfinance mode.
ALPHA_VANTAGE_API_KEY=

# Optional persistence locations
# TRADINGAGENTS_RESULTS_DIR=/root/.tradingagents/logs
# TRADINGAGENTS_CACHE_DIR=/root/.tradingagents/cache
# TRADINGAGENTS_MEMORY_LOG_PATH=/root/.tradingagents/memory/trading_memory.md
